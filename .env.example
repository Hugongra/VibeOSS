# VibeOS — copy to .env.local and fill with YOUR values.
# NEVER commit .env.local, paste secrets in chat, or push keys to Git.

# ---------------------------------------------------------------------------
# Supabase — Postgres (Drizzle migrations + server)
# Dashboard → Project Settings → Database → Connection string (URI)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ---------------------------------------------------------------------------
# Supabase — REST / Auth / client (optional until you use @supabase/supabase-js)
# Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# Public anon key — safe for browser only with Row Level Security enabled
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Server-only — never expose in frontend bundles; full DB access
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# If the React app needs Supabase directly, duplicate the two below with VITE_ prefix:
# VITE_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# VITE_SUPABASE_ANON_KEY="..."

# ---------------------------------------------------------------------------
# OpenAI — schema generation (see src/lib/kernel/schema-generator.ts)
# https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY="sk-proj-..."

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
VITE_APP_URL="http://127.0.0.1:5173"
PORT=3001

# ---------------------------------------------------------------------------
# Providers — Email (Resend)
# https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM="VibeOS <noreply@yourdomain.com>"

# ---------------------------------------------------------------------------
# Providers — Slack (Incoming Webhook)
# https://api.slack.com/messaging/webhooks
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# ============================================
# VibeOS Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- LLM (schema generation) — use OpenRouter OR Anthropic direct ---

# OpenRouter (preferred when set — cheaper models via openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Default model if SCHEMA_GENERATOR_MODEL unset: anthropic/claude-3.5-haiku
# SCHEMA_GENERATOR_MODEL=anthropic/claude-3.5-haiku
# OPENROUTER_HTTP_REFERER=http://localhost:3001
# OPENROUTER_APP_TITLE=VibeOS

# Anthropic direct (used when OPENROUTER_API_KEY is not set)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# SCHEMA_GENERATOR_MODEL=claude-haiku-4-5-20251001

# PostgreSQL connection string
# For Supabase: Project Settings → Database → Connection String → URI
DATABASE_URL=postgresql://user:password@localhost:5432/vibeoss

# Optional: use a fixed org UUID for vibe_modules / vibe_records (otherwise a "default" org is created)
# VIBEOS_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001

# LLM model for schema generation (default: claude-haiku-4-5-20251001)
# SCHEMA_GENERATOR_MODEL=claude-haiku-4-5-20251001

# Self-correction loop: max LLM retries after Zod rejection (default 3, benchmark uses this)
# SCHEMA_GENERATOR_MAX_RETRIES=3

# --- Optional ---

# API server port (default: 3001)
PORT=3001

# Supabase (optional - for future client-side features)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Email provider - Resend (optional - for automation engine)
# RESEND_API_KEY=re_your-key-here

# Slack webhook (optional - for automation engine)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

%% VibeOS — System Flow Diagram
%% Pipeline: Intent → Schema → UI

graph TB
    subgraph User["User Layer"]
        A[Natural Language Intent]
        B[VibeOS Dashboard / Builder]
    end

    subgraph Kernel["Kernel — Deterministic Compiler Shell"]
        C[Schema Generator<br/>Vercel AI SDK + Haiku 4.5]
        N[normalizeLlmModule]
        E[Zod Validator<br/>vibe_schema_v1]
        D[Vibe Parser]
    end

    subgraph API["API Layer"]
        F["/api/vibe<br/>Intent-Based Routing"]
    end

    subgraph Data["Persistence Layer"]
        G[PostgreSQL]
        H[vibe_records JSONB]
        I[vibe_modules JSONB]
    end

    subgraph Engine["Runtime Engine"]
        X[Action Executor]
        Y[Automation Engine]
        P[Providers: Email · Slack · Webhook]
    end

    subgraph UI["Server-Driven UI — React 19"]
        J[Renderer Engine]
        K[Component Factory<br/>Table / Form / Detail / Card]
        L[Rendered Application]
    end

    A -->|"Describe what you want"| F
    F -->|"intent: generate"| C
    C -->|"Raw JSON"| N
    N -->|"Normalized"| E
    E -->|"Validated Schema"| D
    D -->|"Runtime Module"| I
    I -->|"Stored Schema"| H

    B -->|"Request View"| F
    F -->|"intent: query"| H
    H -->|"JSONB Records"| J
    I -->|"View + Entity Schema"| J
    J --> K --> L --> B

    B -->|"Create/Update Record"| F
    F -->|"intent: mutate"| E
    E -->|"Validated Data"| H

    I --> X --> P
    I --> Y --> P

    classDef userStyle fill:#6d5cff,stroke:#5a4dd4,color:#fff
    classDef kernelStyle fill:#1a1a2e,stroke:#6d5cff,color:#fafafa
    classDef apiStyle fill:#0f3460,stroke:#6d5cff,color:#fafafa
    classDef dataStyle fill:#16213e,stroke:#6d5cff,color:#fafafa
    classDef uiStyle fill:#0f3460,stroke:#a78bfa,color:#fafafa
    classDef engineStyle fill:#16213e,stroke:#a78bfa,color:#fafafa

    class A,B userStyle
    class C,N,E,D kernelStyle
    class F apiStyle
    class G,H,I dataStyle
    class J,K,L uiStyle
    class X,Y,P engineStyle

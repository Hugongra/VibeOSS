{
  "version": "1.0.0",
  "module": "simple-crm",
  "description": "CRM module with contacts, companies, and deals — generated by the VibeOS Business Architect.",

  "entities": [
    {
      "name": "contact",
      "label": "Contact",
      "pluralLabel": "Contacts",
      "description": "People the organization interacts with.",
      "icon": "user",
      "timestamps": true,
      "softDelete": true,
      "fields": [
        { "name": "full_name",  "label": "Full Name",  "type": "text",   "required": true,  "validation": { "min_length": 2, "max_length": 120 } },
        { "name": "email",      "label": "Email",      "type": "email",  "required": true,  "unique": true, "validation": { "pattern": "^[^@]+@[^@]+\\.[^@]+$", "message": "Must be a valid email" } },
        { "name": "phone",      "label": "Phone",      "type": "phone",  "required": false },
        { "name": "company_id", "label": "Company",    "type": "relation","required": false, "relation": { "entity": "company", "field": "id", "type": "many-to-many" } },
        { "name": "role",       "label": "Role",       "type": "text",   "required": false },
        { "name": "status",     "label": "Status",     "type": "select", "required": true,  "options": ["Lead", "Active", "Inactive"], "defaultValue": "Lead" }
      ]
    },
    {
      "name": "company",
      "label": "Company",
      "pluralLabel": "Companies",
      "description": "Organizations in the pipeline.",
      "icon": "building",
      "timestamps": true,
      "softDelete": true,
      "fields": [
        { "name": "name",       "label": "Company Name","type": "text",     "required": true, "validation": { "min_length": 1, "max_length": 200 } },
        { "name": "domain",     "label": "Domain",      "type": "url",     "required": false, "unique": true },
        { "name": "industry",   "label": "Industry",    "type": "select",  "required": false, "options": ["SaaS", "Fintech", "Healthcare", "E-commerce", "Education", "Other"] },
        { "name": "size",       "label": "Size",        "type": "select",  "required": false, "options": ["1-10", "11-50", "51-200", "201-1000", "1000+"] },
        { "name": "annual_revenue", "label": "Annual Revenue", "type": "currency", "required": false, "validation": { "min": 0 } }
      ]
    },
    {
      "name": "deal",
      "label": "Deal",
      "pluralLabel": "Deals",
      "description": "Sales opportunities tracked through a pipeline.",
      "icon": "dollar-sign",
      "timestamps": true,
      "softDelete": true,
      "fields": [
        { "name": "title",      "label": "Deal Title", "type": "text",     "required": true },
        { "name": "amount",     "label": "Amount",     "type": "currency", "required": true, "validation": { "min": 0 } },
        { "name": "stage",      "label": "Stage",      "type": "select",   "required": true, "options": ["Prospecting", "Qualification", "Proposal", "Negotiation", "Closed Won", "Closed Lost"], "defaultValue": "Prospecting" },
        { "name": "probability","label": "Probability", "type": "percentage","required": false, "validation": { "min": 0, "max": 100 } },
        { "name": "close_date", "label": "Expected Close", "type": "date", "required": false },
        { "name": "contact_id", "label": "Contact",    "type": "relation", "required": true, "relation": { "entity": "contact", "field": "id", "type": "many-to-many" } },
        { "name": "company_id", "label": "Company",    "type": "relation", "required": false,"relation": { "entity": "company", "field": "id", "type": "many-to-many" } },
        { "name": "notes",      "label": "Notes",      "type": "rich-text","required": false }
      ]
    }
  ],

  "views": [
    {
      "name": "contacts_list",
      "label": "All Contacts",
      "entity": "contact",
      "layout": { "type": "table", "columns": ["full_name", "email", "phone", "status"], "pageSize": 25, "sorting": [{ "field": "full_name", "direction": "asc" }] },
      "actions": [
        { "name": "add_contact",  "label": "New Contact", "type": "create", "icon": "plus" },
        { "name": "export_csv",   "label": "Export CSV",  "type": "export", "icon": "download" }
      ]
    },
    {
      "name": "contact_form",
      "label": "Contact Form",
      "entity": "contact",
      "layout": { "type": "form" }
    },
    {
      "name": "companies_list",
      "label": "All Companies",
      "entity": "company",
      "layout": { "type": "table", "columns": ["name", "domain", "industry", "size"], "pageSize": 25 },
      "actions": [
        { "name": "add_company", "label": "New Company", "type": "create", "icon": "plus" }
      ]
    },
    {
      "name": "company_form",
      "label": "Company Form",
      "entity": "company",
      "layout": { "type": "form" }
    },
    {
      "name": "deals_pipeline",
      "label": "Pipeline",
      "entity": "deal",
      "layout": { "type": "kanban", "groupBy": "stage", "columns": ["title", "amount", "probability"] },
      "actions": [
        { "name": "add_deal",    "label": "New Deal",  "type": "create",     "icon": "plus" },
        { "name": "mark_won",    "label": "Mark Won",  "type": "transition", "icon": "check", "confirmation": "Mark this deal as Won?", "transition": { "field": "stage", "to": "Closed Won" } },
        { "name": "mark_lost",   "label": "Mark Lost", "type": "transition", "icon": "x",     "confirmation": "Mark this deal as Lost?", "transition": { "field": "stage", "to": "Closed Lost" } }
      ]
    },
    {
      "name": "deal_form",
      "label": "Deal Form",
      "entity": "deal",
      "layout": { "type": "form" }
    },
    {
      "name": "deals_table",
      "label": "Deals Table",
      "entity": "deal",
      "layout": { "type": "table", "columns": ["title", "amount", "stage", "probability", "close_date"], "pageSize": 25, "sorting": [{ "field": "close_date", "direction": "asc" }] }
    }
  ],

  "actions": [
    { "name": "notify_team_slack",  "label": "Notify Team (Slack)",  "type": "notify", "icon": "bell",     "notification": { "channel": "slack", "template": "New deal \"{{title}}\" worth {{amount}}" } },
    { "name": "notify_email",       "label": "Send Email",           "type": "notify", "icon": "mail",     "notification": { "channel": "email" } },
    { "name": "approve_deal",       "label": "Approve Deal",         "type": "approve","icon": "thumbs-up","confirmation": "Approve this deal for processing?" }
  ],

  "automations": [
    {
      "name": "welcome_new_contact",
      "label": "Send welcome email on new contact",
      "entity": "contact",
      "trigger": "on_create",
      "actions": [
        { "name": "send_welcome", "label": "Welcome Email", "type": "notify", "notification": { "channel": "email", "template": "Welcome {{full_name}}! We're glad to connect.", "recipients": "{{email}}" } }
      ]
    },
    {
      "name": "notify_deal_won",
      "label": "Notify team when deal is won",
      "entity": "deal",
      "trigger": "on_field_change",
      "watchField": "stage",
      "condition": { "field": "stage", "operator": "eq", "value": "Closed Won" },
      "actions": [
        { "name": "slack_won", "label": "Slack — Deal Won", "type": "notify", "notification": { "channel": "slack", "template": "Deal \"{{title}}\" closed for {{amount}}!" } }
      ]
    },
    {
      "name": "notify_deal_lost",
      "label": "Notify team when deal is lost",
      "entity": "deal",
      "trigger": "on_field_change",
      "watchField": "stage",
      "condition": { "field": "stage", "operator": "eq", "value": "Closed Lost" },
      "actions": [
        { "name": "slack_lost", "label": "Slack — Deal Lost", "type": "notify", "notification": { "channel": "slack", "template": "Deal \"{{title}}\" was lost." } }
      ]
    }
  ],

  "navigation": [
    { "label": "Contacts",  "icon": "users",        "view": "contacts_list" },
    { "label": "Companies", "icon": "building",      "view": "companies_list" },
    { "label": "Pipeline",  "icon": "git-branch",    "view": "deals_pipeline" },
    { "label": "Deals",     "icon": "dollar-sign",   "view": "deals_table" }
  ]
}
